{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and settings",
      "type": "object",
      "properties": {
        "apiKey": {
          "type": "string",
          "description": "User's Gemini API key"
        },
        "email": {
          "type": "string",
          "description": "User's email"
        },
        "displayName": {
          "type": "string",
          "description": "User's display name"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Last update timestamp"
        }
      },
      "required": ["email", "updatedAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "User-specific data"
    }
  }
}
