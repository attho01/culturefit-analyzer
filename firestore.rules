rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User validation helper
    function isValidUser(data) {
      return data.keys().hasAll(['email', 'updatedAt']) &&
             data.email is string && data.email.size() <= 100 &&
             data.updatedAt == request.time &&
             (!data.keys().contains('apiKey') || (data.apiKey is string && data.apiKey.size() <= 200)) &&
             (!data.keys().contains('displayName') || (data.displayName is string && data.displayName.size() <= 100));
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isVerified() && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isVerified() && isValidUser(incoming()) &&
                      incoming().email == existing().email;
    }
  }
}
